{
  "name": "single-thread-chat",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:init": "bash scripts/init-db.sh",
    "letta:docker:build": "bash scripts/letta-docker-build.sh",
    "letta:docker:build:clone": "bash scripts/letta-docker-build.sh --clone",
    "letta:compose:build": "docker-compose -f docker-compose.yml -f docker-compose.letta-from-source.yml build letta",
    "letta:db:migrate": "bash scripts/letta-db-migrate.sh",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@letta-ai/letta-client": "^1.10.3",
    "@prisma/client": "^6.3.0",
    "dotenv": "^17.4.2",
    "next": "^15.2.6",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "embedded-postgres": "^18.3.0-beta.17",
    "jsdom": "^26.0.0",
    "prisma": "^6.3.0",
    "typescript": "~5.7.2",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "postcss": "^8.4.49"
  }
}
