# Used by docker-compose for the `letta` service (`docker-compose up letta`).
# Local image: `npm run letta:docker:build` then `LETTA_DOCKER_IMAGE=letta:local docker-compose up -d letta_db letta`.
# DB tables (Alembic): `docker/letta-init.sql` prepares Postgres; `npm run letta:db:migrate` runs
# `alembic upgrade head` (same as Letta CONTRIBUTING.md). The Letta container also migrates on startup.
# Compose sets `LETTA_PG_URI` on the Letta container (letta_db + letta server); you usually omit it here.
# Also merged into the Next.js API route (`/api/letta/send`) — copy to `.env.letta`.
#
#   cp .env.letta.example .env.letta
#
# Docs: https://docs.letta.com/guides/selfhosting

# --- Next.js + Letta API (same variables can live in root `.env` instead; root wins if both set)
# Prisma: matches docker-compose `db` (user postgres / DB singlethread). 127.0.0.1 avoids macOS ::1 vs Docker.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/singlethread?schema=public"
# After `npm run db:init`, you can use the app role instead:
# DATABASE_URL="postgresql://singlethread:singlethread@127.0.0.1:5432/singlethread?schema=public"

# Agent id fallback (guest / localStorage chat and profiles without a stored agent).
# Each signed-in profile normally gets its own agent on create; this is optional then.
# LETTA_AGENT_ID="agent-xxxxxxxx"
#
# Optional defaults when auto-creating an agent for a new profile (self-hosted CreateAgent / LLMConfig).
# Handles may include a provider prefix; the server uses short model ids (e.g. gpt-4o-mini).
# LETTA_NEW_AGENT_MODEL="openai/gpt-4o-mini"
# LETTA_NEW_AGENT_EMBEDDING="openai/text-embedding-3-small"
# LETTA_NEW_AGENT_CONTEXT_WINDOW="128000"
# LETTA_NEW_AGENT_EMBEDDING_DIM="1536"
# LETTA_NEW_AGENT_OPENAI_ENDPOINT="https://api.openai.com/v1"
# LETTA_BASE_URL="http://127.0.0.1:8283"
# LETTA_API_KEY="" # same as LETTA_SERVER_PASSWORD if SECURE=true on Letta
#
# Optional: comma/space-separated agent ids to never delete during orphan cleanup (e.g. ADE experiments).
# LETTA_AGENT_IDS_TO_KEEP="agent-aaa agent-bbb"
#
# Cron: remove Letta agents not linked to any profile (POST /api/cron/reconcile-letta-agents).
#   curl -sS -X POST http://127.0.0.1:3000/api/cron/reconcile-letta-agents
# Optional: set CRON_SECRET and send Authorization: Bearer … to lock the route down.
# CRON_SECRET=
#
# Long-running `next start` (not Vercel): periodic ping via src/instrumentation.ts
# RECONCILE_LETTA_INTERVAL_MS="3600000"
# RECONCILE_LETTA_INITIAL_DELAY_MS="15000"
# Optional full URL; default is RECONCILE_LETTA_BASE_URL or http://127.0.0.1:$PORT/api/cron/reconcile-letta-agents
# RECONCILE_LETTA_PING_URL="http://127.0.0.1:3000/api/cron/reconcile-letta-agents"
# RECONCILE_LETTA_BASE_URL="http://127.0.0.1:3000"

# Required for OpenAI models inside Letta (recommended starting point)
OPENAI_API_KEY=

# Optional: other providers — uncomment if you use them
# ANTHROPIC_API_KEY=
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Optional: lock down the API (use the same value as LETTA_API_KEY above / in root `.env`)
# SECURE=true
# LETTA_SERVER_PASSWORD=

# Optional: share Postgres with Letta (needs pgvector). Usually omit for local Docker image.
# LETTA_PG_URI=

# Optional: MemFS local mode — https://docs.letta.com/guides/selfhosting
# LETTA_MEMFS_SERVICE_URL=local
