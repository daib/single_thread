# Used by docker-compose for the `letta` service (`docker compose up letta`).
# Copy this file to `.env.letta` and fill in values (`.env.letta` is gitignored).
#
#   cp .env.letta.example .env.letta
#
# Docs: https://docs.letta.com/guides/selfhosting

# Required for OpenAI models inside Letta (recommended starting point)
OPENAI_API_KEY=

# Optional: other providers — uncomment if you use them
# ANTHROPIC_API_KEY=
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Optional: lock down the API (use the same value as LETTA_API_KEY in your app `.env`)
# SECURE=true
# LETTA_SERVER_PASSWORD=

# Optional: share Postgres with Letta (needs pgvector). Usually omit for local Docker image.
# LETTA_PG_URI=

# Optional: MemFS local mode — https://docs.letta.com/guides/selfhosting
# LETTA_MEMFS_SERVICE_URL=local

ZAPIER_API_KEY=
