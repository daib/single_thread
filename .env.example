# Postgres (matches docker-compose.yml — use 127.0.0.1 on macOS so you hit Docker, not ::1 / Homebrew)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/singlethread?schema=public"

# After `npm run db:init`, you can switch to the app role (default user/pass: singlethread/singlethread):
# DATABASE_URL="postgresql://singlethread:singlethread@127.0.0.1:5432/singlethread?schema=public"
