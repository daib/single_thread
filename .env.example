# Postgres (matches docker-compose.yml — use 127.0.0.1 on macOS so you hit Docker, not ::1 / Homebrew)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/singlethread?schema=public"

# After `npm run db:init`, you can switch to the app role (default user/pass: singlethread/singlethread):
# DATABASE_URL="postgresql://singlethread:singlethread@127.0.0.1:5432/singlethread?schema=public"

# Auth.js / Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Facebook Login (optional) — https://developers.facebook.com/apps/ — add “Facebook Login” product
# Valid OAuth redirect URI: http://localhost:3000/api/auth/callback/facebook
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""

# Optional in dev; set in production (e.g. https://yourdomain.com)
# AUTH_URL="http://localhost:3000"

# Letta (optional): forward each chat send to an agent — docker-compose exposes 8283
# LETTA_AGENT_ID="agent-xxxxxxxx"
# LETTA_BASE_URL="http://127.0.0.1:8283"
# LETTA_API_KEY="" # Bearer token if Letta is secured (LETTA_SERVER_PASSWORD / cloud)

# Letta Docker (optional): copy .env.letta.example → .env.letta for `docker compose up letta`
