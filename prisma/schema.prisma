generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// One row per signed-in user (Auth.js JWT `sub` / `session.user.id`).
model AppAccount {
  id          String       @id @default(uuid())
  userId      String       @unique @map("user_id")
  handle      String       @unique
  displayName String       @map("display_name")
  bio         String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  profiles    AppProfile[]

  @@map("accounts")
}

/// Persona under an account; handle unique within that account.
model AppProfile {
  id             String             @id @default(uuid())
  accountId      String             @map("account_id")
  account        AppAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  displayName    String             @map("display_name")
  handle         String
  bio            String?
  /** Letta agent id created for this profile (falls back to LETTA_AGENT_ID when null). */
  lettaAgentId   String?            @map("letta_agent_id")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  conversations  ChatConversation[]

  @@unique([accountId, handle])
  @@map("profiles")
}

/// Chat thread for a profile (messages stored in `ChatMessage`).
model ChatConversation {
  id          String    @id @default(uuid())
  profileId   String    @map("profile_id")
  profile     AppProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  /** One Letta conversation id per app chat thread (isolated server-side context). */
  lettaConversationId String? @map("letta_conversation_id")
  title       String
  preview     String    @default("")
  branchOfId  String?   @map("branch_of_id")
  /** For branched threads: set true after branch-specific setup (e.g. first Letta turn) is complete. */
  isBranchInitialized Boolean @default(false) @map("is_branch_initialized")
  parent      ChatConversation?  @relation("ConversationBranch", fields: [branchOfId], references: [id], onDelete: SetNull)
  branches    ChatConversation[] @relation("ConversationBranch")
  messages    ChatMessage[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([profileId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String           @map("conversation_id")
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  body           String
  sentAt         DateTime         @default(now()) @map("sent_at")

  @@index([conversationId])
  @@map("chat_messages")
}
